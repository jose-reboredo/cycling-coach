# tsconfig.node.json (composite: true) emits .js/.d.ts for all its
# included files. vite.config.ts imports src/lib/changelogParser, so
# those compiled siblings end up next to the .ts. They're never
# imported by the app — Vite uses the .ts directly — so ignore.
src/lib/changelogParser.js
src/lib/changelogParser.d.ts

# routeTree.gen.ts is auto-generated by @tanstack/router-plugin during
# vite dev/build. Committed (not gitignored) so CI's tsc -b can resolve
# the './routeTree.gen' import — the plugin only regenerates during
# vite, not during tsc, and tsc runs first in the build script.
# Per Tanstack Router docs, committing is the supported pattern.
