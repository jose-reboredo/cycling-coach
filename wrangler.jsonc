{
	"name": "cycling-coach",
	"main": "src/worker.js",
	"workers_dev": true,
	"preview_urls": false,
	"compatibility_date": "2026-04-26",
	// PARS v8 — Workers Static Assets (replaces the legacy Pages flow).
	// The React SPA in apps/web ships as assets; the Worker only runs for the
	// listed `run_worker_first` paths (auth + Strava + AI proxy + webhook).
	"assets": {
		"directory": "./apps/web/dist",
		"binding": "ASSETS",
		"not_found_handling": "single-page-application",
		"run_worker_first": [
			"/api/*",
			"/authorize",
			"/callback",
			"/authorize-rwgps",
			"/callback-rwgps",
			"/refresh",
			"/coach",
			"/coach-ride",
			"/webhook",
			"/webhook/*",
			"/version",
			"/roadmap",
			"/admin/*"
		]
	},
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"persist": true,
			"invocation_logs": true
		},
		"traces": {
			"enabled": false,
			"persist": true,
			"head_sampling_rate": 1
		}
	},
	"d1_databases": [
		{
			"binding": "cycling_coach_db",
			"database_name": "cycling-coach-db",
			"database_id": "bfc42f0f-a043-4058-854d-d8ebed9a8e4c"
		}
	],
	// Non-sensitive Confluence config (issue #23 — auto-doc-on-deploy).
	// Sensitive values (CONFLUENCE_API_TOKEN, CONFLUENCE_USER_EMAIL, ADMIN_SECRET,
	// SYSTEM_ANTHROPIC_KEY) live in `wrangler secret put`.
	"vars": {
		"CONFLUENCE_BASE_URL": "https://josemreboredo.atlassian.net",
		"CONFLUENCE_SPACE_KEY": "CC",
		"CONFLUENCE_HOMEPAGE_ID": "262256",
		"GITHUB_OWNER": "jose-reboredo",
		"GITHUB_REPO": "jose-reboredo/cycling-coach"
	},
	"kv_namespaces": [
		// Confluence page-id caching + admin rate-limit counters (#23, #18).
		{
			"binding": "DOCS_KV",
			"id": "db369961d8d84acaac83d90ca9c438a8"
		},
		// OAuth state nonce store (#14 — single-use, 10-min TTL). Replaces
		// the deterministic base64({pwa,origin}) state with a UUID stored
		// here; /callback looks it up + deletes on use.
		{
			"binding": "OAUTH_STATE",
			"id": "9b77ecf8836240db9f1c126ce715414d"
		}
	]
}
